{
  "model_profile": "balanced",
  "commit_docs": true,
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": true,
    "max_concurrent_agents": 4,
    "min_plans_for_parallel": 2
  },
  "search_gitignored": true,
  "brave_search": false,
  "firecrawl": false,
  "exa_search": true,
  "git": {
    "branching_strategy": "milestone",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": "gsd/quick-{num}-{slug}",
    "base_branch": "main"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "ui_phase": true,
    "ui_safety_gate": true,
    "text_mode": false,
    "research_before_questions": true,
    "discuss_mode": "assumptions",
    "skip_discuss": false,
    "code_review": true,
    "code_review_depth": "standard",
    "use_worktrees": false
  },
  "hooks": {
    "context_warnings": true
  },
  "project_code": null,
  "phase_naming": "sequential",
  "agent_skills": {},
  "features": {
    "global_learnings": true
  },
  "mode": "interactive",
  "granularity": "standard",
  "runtime": "opencode",
  "model_profile_overrides": {
    "opencode": {
      "opus": "openai/gpt-5.4",
      "sonnet": "openai/gpt-5.3-codex",
      "haiku": "openai/gpt-5.4-mini"
    }
  },
  "planning": {
    "commit_docs": true,
    "search_gitignored": false
  },
  "intel": {
    "enabled": true
  },
  "claude_md_path": "./AGENTS.md",
  "resolve_model_ids": "omit",
  "model_overrides": {
    "gsd-project-researcher": "openai/gpt-5.4",
    "gsd-phase-researcher": "openai/gpt-5.3-codex",
    "gsd-ui-researcher": "openai/gpt-5.4",
    "gsd-assumptions-analyzer": "openai/gpt-5.4",
    "gsd-advisor-researcher": "openai/gpt-5.4",
    "gsd-research-synthesizer": "openai/gpt-5.4",
    "gsd-planner": "openai/gpt-5.4",
    "gsd-roadmapper": "openai/gpt-5.4",
    "gsd-executor": "openai/gpt-5.3-codex",
    "gsd-plan-checker": "openai/gpt-5.4",
    "gsd-integration-checker": "openai/gpt-5.4",
    "gsd-ui-checker": "openai/gpt-5.4",
    "gsd-verifier": "openai/gpt-5.4",
    "gsd-nyquist-auditor": "openai/gpt-5.3-codex",
    "gsd-ui-auditor": "openai/gpt-5.4",
    "gsd-codebase-mapper": "openai/gpt-5.4-mini",
    "gsd-debugger": "openai/gpt-5.4",
    "gsd-user-profiler": "openai/gpt-5.4",
    "gsd-doc-writer": "openai/gpt-5.4-mini",
    "gsd-doc-verifier": "openai/gpt-5.4-mini",
    "gsd-security-auditor": "openai/gpt-5.4",
    "gsd-pattern-mapper": "openai/gpt-5.4-mini",
    "gsd-debug-session-manager": "openai/gpt-5.4",
    "gsd-code-reviewer": "openai/gpt-5.3-codex",
    "gsd-code-fixer": "openai/gpt-5.3-codex",
    "gsd-ai-researcher": "openai/gpt-5.3-codex",
    "gsd-domain-researcher": "openai/gpt-5.3-codex",
    "gsd-eval-planner": "openai/gpt-5.4",
    "gsd-eval-auditor": "openai/gpt-5.4",
    "gsd-framework-selector": "openai/gpt-5.4",
    "gsd-intel-updater": "openai/gpt-5.4-mini",
    "gsd-doc-classifier": "openai/gpt-5.4-mini",
    "gsd-doc-synthesizer": "openai/gpt-5.4"
  }
}
