<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DevProxy Doctor</title>
  <link rel="stylesheet" href="/static/dashboard.css" />
</head>
<body>
  <div class="app-layout">
    {{template "nav" .}}
    <main class="main-content">
      <div class="shell" id="doctor-page">
        <section class="card">
          <div class="card-header">
            <h1>Doctor</h1>
            <span class="polling-indicator" id="poll-indicator">
              <span class="pulse"></span>
              <span id="poll-text">Live</span>
            </span>
          </div>
          {{if .DaemonError}}
          <p class="error" id="daemon-error">{{.DaemonError}}</p>
          {{end}}

          <div class="status-grid" id="doctor-grid">
            <div class="status-item">
              <div class="label">Conflicts</div>
              <div class="value" id="doc-conflicts">{{.Doctor.ConflictCount}}</div>
            </div>
            <div class="status-item">
              <div class="label">Warnings</div>
              <div class="value" id="doc-warnings">{{.Doctor.WarningCount}}</div>
            </div>
            <div class="status-item">
              <div class="label">DNS</div>
              <div class="value" id="doc-dns">{{if .Doctor.Network.DNSHealthy}}<span class="badge badge-success">Healthy</span>{{else}}<span class="badge badge-error">Unhealthy</span>{{end}}</div>
            </div>
            <div class="status-item">
              <div class="label">HTTP</div>
              <div class="value" id="doc-http">{{if .Doctor.Network.HTTPBound}}<span class="badge badge-success">Bound</span>{{else}}<span class="badge badge-error">Not Bound</span>{{end}}</div>
            </div>
            <div class="status-item">
              <div class="label">HTTPS</div>
              <div class="value" id="doc-https">{{if .Doctor.Network.HTTPSBound}}<span class="badge badge-success">Bound</span>{{else}}<span class="badge badge-error">Not Bound</span>{{end}}</div>
            </div>
            <div class="status-item">
              <div class="label">Certificate</div>
              <div class="value" id="doc-cert">{{if .Doctor.Network.CertificateReady}}<span class="badge badge-success">Ready</span>{{else}}<span class="badge badge-warning">Not Ready</span>{{end}}</div>
            </div>
          </div>
        </section>

        <section class="card">
          <h2>Conflicts</h2>
          <ul class="log-list" id="doc-conflicts-list">
            {{range .Doctor.Conflicts}}
            <li class="log-item">
              <span class="log-type log-type-conflict">Conflict</span>
              <span class="log-message">{{.Reason}}</span>
              <span class="log-hostname">{{.Hostname}}</span>
            </li>
            {{else}}
            <li class="empty-state">No conflicts</li>
            {{end}}
          </ul>
        </section>

        <section class="card">
          <h2>Warnings</h2>
          <ul class="log-list" id="doc-warnings-list">
            {{range .Doctor.Warnings}}
            <li class="log-item">
              <span class="log-type log-type-warning">Warning</span>
              <span class="log-message">{{.Message}}</span>
            </li>
            {{else}}
            <li class="empty-state">No warnings</li>
            {{end}}
          </ul>
        </section>
      </div>

      <script>
      (function() {
        const pollInterval = 3000;

        function setOnline(online) {
          const indicator = document.getElementById('poll-indicator');
          const text = document.getElementById('poll-text');
          if (indicator) indicator.classList.toggle('offline', !online);
          if (text) text.textContent = online ? 'Live' : 'Offline';
        }

        function escapeHtml(str) {
          if (str == null) return '';
          return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

        function badge(label, good) {
          return good
            ? '<span class="badge badge-success">' + escapeHtml(label) + '</span>'
            : '<span class="badge badge-error">' + escapeHtml(label) + '</span>';
        }

        async function poll() {
          try {
            const res = await fetch('/api/doctor', { method: 'GET', headers: { 'Accept': 'application/json' } });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            setOnline(true);

            if (data.daemon_error) {
              let errEl = document.getElementById('daemon-error');
              if (!errEl) {
                errEl = document.createElement('p');
                errEl.className = 'error';
                errEl.id = 'daemon-error';
                const grid = document.getElementById('doctor-grid');
                if (grid) grid.parentNode.insertBefore(errEl, grid);
              }
              errEl.textContent = data.daemon_error;
            } else {
              const errEl = document.getElementById('daemon-error');
              if (errEl) errEl.remove();
            }

            if (data.doctor) {
              const d = data.doctor;
              const conflictsEl = document.getElementById('doc-conflicts');
              const warningsEl = document.getElementById('doc-warnings');
              if (conflictsEl) conflictsEl.textContent = String(d.ConflictCount || 0);
              if (warningsEl) warningsEl.textContent = String(d.WarningCount || 0);

              const dnsEl = document.getElementById('doc-dns');
              const httpEl = document.getElementById('doc-http');
              const httpsEl = document.getElementById('doc-https');
              const certEl = document.getElementById('doc-cert');

              if (dnsEl) dnsEl.innerHTML = badge('Healthy', d.Network && d.Network.DNSHealthy);
              if (httpEl) httpEl.innerHTML = badge('Bound', d.Network && d.Network.HTTPBound);
              if (httpsEl) httpsEl.innerHTML = badge('Bound', d.Network && d.Network.HTTPSBound);
              if (certEl) certEl.innerHTML = d.Network && d.Network.CertificateReady
                ? '<span class="badge badge-success">Ready</span>'
                : '<span class="badge badge-warning">Not Ready</span>';

              const cList = document.getElementById('doc-conflicts-list');
              if (cList) {
                if ((d.Conflicts || []).length === 0) {
                  cList.innerHTML = '<li class="empty-state">No conflicts</li>';
                } else {
                  cList.innerHTML = (d.Conflicts || []).map(function(c) {
                    return '<li class="log-item"><span class="log-type log-type-conflict">Conflict</span><span class="log-message">' + escapeHtml(c.Reason || '') + '</span><span class="log-hostname">' + escapeHtml(c.Hostname || '') + '</span></li>';
                  }).join('');
                }
              }

              const wList = document.getElementById('doc-warnings-list');
              if (wList) {
                if ((d.Warnings || []).length === 0) {
                  wList.innerHTML = '<li class="empty-state">No warnings</li>';
                } else {
                  wList.innerHTML = (d.Warnings || []).map(function(w) {
                    return '<li class="log-item"><span class="log-type log-type-warning">Warning</span><span class="log-message">' + escapeHtml(w.Message || '') + '</span></li>';
                  }).join('');
                }
              }
            }
          } catch (e) {
            setOnline(false);
            console.error('Doctor poll failed:', e);
          }
        }

        setInterval(poll, pollInterval);
        setTimeout(poll, 500);
      })();
      </script>
    </main>
  </div>
</body>
</html>
